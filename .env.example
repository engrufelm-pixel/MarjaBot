# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# AITunnel API Key (получить на aitunnel.ru)
AITUNNEL_API_KEY=sk-your-aitunnel-key-here

# AITunnel Base URL (не менять без необходимости)
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1

# Путь к базе данных SQLite
DATABASE_URL=sqlite+aiosqlite:///./marja_bot.db
